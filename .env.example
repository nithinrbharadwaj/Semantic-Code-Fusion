# === AI Configuration ===
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# === Database ===
DATABASE_URL=postgresql+asyncpg://scf_user:scf_pass@localhost:5432/semantic_code_fusion
SYNC_DATABASE_URL=postgresql://scf_user:scf_pass@localhost:5432/semantic_code_fusion

# === Redis & Celery ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# === Vector Store ===
FAISS_INDEX_PATH=./data/faiss_index
FAISS_DIMENSION=1536

# === App Settings ===
APP_NAME=Semantic Code Fusion
APP_VERSION=2.0.0
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# === Fusion Settings ===
MAX_CODE_LENGTH=50000
DEFAULT_FUSION_TEMPERATURE=0.2
MAX_RETRIES=3
FUSION_TIMEOUT_SECONDS=120

# === Security Scanning ===
ENABLE_SECURITY_SCAN=true
SECURITY_SCAN_LEVEL=medium

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
